# config/.env.example
# Скопируйте в .env и заполните своими данными

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- Jira ---
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_CLOUD=true
# JIRA_PROJECT=TASKS

# --- Confluence ---
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_CLOUD=true
# CONFLUENCE_SPACE=TASKS

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdefghIJKlmnoPQRstUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# --- Mattermost ---
# MATTERMOST_WEBHOOK_URL=https://mattermost.example.com/hooks/xxxxx

# --- SMTP (Email) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifier@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=case10@example.com

# --- IMAP (Email input) ---
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=incoming@example.com
# IMAP_PASSWORD=your-imap-password
